# .env.example — copy to .env and fill in your values
# Never commit .env to version control

# ── LLM provider (llmod.ai — OpenAI-compatible endpoint) ──────────────────────
# This is NOT a direct OpenAI key. Use an API key issued by llmod.ai.
OPENAI_API_KEY=your_llmod_api_key_here

# Base URL for the OpenAI-compatible endpoint
BASE_URL=https://api.llmod.ai/v1

# Model name for chat completions (vendor-prefixed identifier)
GPT_MODEL=RPRTHPB-gpt-5-mini

# ── Pinecone (vector search) ───────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here

# ── Supabase (PostgreSQL) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# ── statement-processor (local development only) ──────────────────────────────
# Path to the local SQLite database used by the statement-processor pipeline.
# Defaults to src/statement-processor/data/political_dossier.db if not set.
# STATEMENT_PROCESSOR_DB_PATH=src/statement-processor/data/political_dossier.db

# Path to the news_articles CSV export used for local ingestion.
# Defaults to src/statement-processor/data/news_articles.csv if not set.
# STATEMENT_PROCESSOR_CSV_PATH=src/statement-processor/data/news_articles.csv
